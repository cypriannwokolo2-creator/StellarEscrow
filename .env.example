# StellarEscrow — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env files.

# ── Stellar Network ──────────────────────────────────────────────────────────
STELLAR_NETWORK=TESTNET
HORIZON_URL=https://horizon-testnet.stellar.org
CONTRACT_ID=

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/stellar_escrow

# ── API Server ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Auth ─────────────────────────────────────────────────────────────────────
API_KEYS=demo-key-123,client-key-456
ADMIN_KEYS=admin-key-123

# ── Optional ─────────────────────────────────────────────────────────────────
REDIS_URL=
LOG_LEVEL=debug

# ── Monitoring & Alerting ─────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=
GRAFANA_URL=http://localhost:3002
ALERT_WEBHOOK_URL=http://indexer:3000/monitoring/alerts
INCIDENT_WEBHOOK_URL=http://indexer:3000/monitoring/alerts
PAGERDUTY_ROUTING_KEY=
ONCALL_EMAIL=oncall@stellarescrow.app
SMTP_HOST=localhost:587
SMTP_FROM=alerts@stellarescrow.app
SMTP_USER=
SMTP_PASSWORD=
