{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@stellar-escrow/components/*": ["../../components/src/*"]
    }
  },
  "include": ["suites/**/*", "setup/**/*", "helpers/**/*"],
  "exclude": ["node_modules", "dist", "reports"]
}
