{
  "name": "@stellar-escrow/accessibility-tests",
  "version": "1.0.0",
  "description": "Automated accessibility testing suite for StellarEscrow",
  "private": true,
  "scripts": {
    "test": "jest --runInBand",
    "test:ci": "jest --runInBand --ci --json --outputFile=reports/a11y-results.json",
    "test:components": "jest --testPathPattern=components",
    "test:frontend": "jest --testPathPattern=frontend",
    "report": "node scripts/generate-a11y-report.js",
    "cypress:a11y": "cypress run --spec 'cypress/e2e/a11y-*.cy.ts'"
  },
  "dependencies": {
    "axe-core": "^4.8.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@axe-core/react": "^4.8.0",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.0",
    "@types/jest": "^29.5.10",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.2"
  }
}
