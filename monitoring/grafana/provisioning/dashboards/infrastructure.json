{
  "title": "StellarEscrow Infrastructure",
  "uid": "stellar-escrow-infra",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Services Up",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "count(up == 1)", "legendFormat": "Up" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [{ "color": "green", "value": 0 }] }
        }
      }
    },
    {
      "id": 2,
      "title": "Services Down",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "count(up == 0) or vector(0)", "legendFormat": "Down" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "CPU Usage (%)",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "100 - (avg(rate(node_cpu_seconds_total{mode='idle'}[5m])) * 100)",
        "legendFormat": "CPU %"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 85 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Memory Usage (%)",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
        "legendFormat": "Memory %"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 85 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Disk Usage (%)",
      "type": "gauge",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "(1 - (node_filesystem_avail_bytes{mountpoint='/',fstype!~'tmpfs|overlay'} / node_filesystem_size_bytes{mountpoint='/',fstype!~'tmpfs|overlay'})) * 100",
        "legendFormat": "Disk %"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Active Alerts",
      "type": "stat",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "count(ALERTS{alertstate='firing'}) or vector(0)", "legendFormat": "Firing" }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "CPU Usage Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode='idle'}[5m])) * 100)",
        "legendFormat": "{{ instance }}"
      }],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 8,
      "title": "Memory Usage Over Time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
        "legendFormat": "{{ instance }}"
      }],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 9,
      "title": "PostgreSQL Connections",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 6 },
      "targets": [
        { "expr": "pg_stat_activity_count", "legendFormat": "Active" },
        { "expr": "pg_settings_max_connections", "legendFormat": "Max" }
      ]
    },
    {
      "id": 10,
      "title": "Redis Hit Rate (%)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 12, "w": 8, "h": 6 },
      "targets": [{
        "expr": "rate(redis_keyspace_hits_total[5m]) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m])) * 100",
        "legendFormat": "Hit Rate %"
      }],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 11,
      "title": "Network I/O (bytes/s)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 12, "w": 8, "h": 6 },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{device!='lo'}[5m])", "legendFormat": "RX {{ device }}" },
        { "expr": "rate(node_network_transmit_bytes_total{device!='lo'}[5m])", "legendFormat": "TX {{ device }}" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "id": 12,
      "title": "Application Logs (Errors)",
      "type": "logs",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 8 },
      "targets": [{
        "datasource": { "type": "loki", "uid": "loki" },
        "expr": "{job=\"stellar-escrow\"} |= \"ERROR\"",
        "legendFormat": ""
      }],
      "options": { "showTime": true, "showLabels": true, "wrapLogMessage": true }
    }
  ]
}
