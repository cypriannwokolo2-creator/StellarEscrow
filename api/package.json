{
  "name": "@stellar-escrow/api",
  "version": "1.0.0",
  "description": "API integration layer for StellarEscrow",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand unit",
    "test:endpoints": "jest --runInBand endpoint",
    "test:integration": "jest --runInBand integration",
    "test:contract": "jest --runInBand contract",
    "test:load": "jest --runInBand load",
    "test:stress": "jest --runInBand stress",
    "test:benchmark": "jest --runInBand benchmark",
    "test:scalability": "jest --runInBand scalability",
    "test:monitoring": "jest --runInBand monitoring",
    "test:performance": "jest --runInBand --testPathPattern='api\\.(load|stress|benchmark|scalability|monitoring)\\.test\\.ts'",
    "test:docs": "jest --runInBand documentation",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "msw": "^1.3.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.10",
    "@types/node": "^22.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.2"
  }
}
